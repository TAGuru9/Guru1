private String normalize(String value) {
    if (value == null) {
        return "";
    }

    return value
            .replace('\u00A0', ' ')
            .replaceAll("[\\u200B-\\u200D\\uFEFF]", "")
            .replaceAll("[\\u0000-\\u001F\\u007F]", "")
            .replaceAll("[\\t\\n\\r]+", "")
            .replaceAll("\\s+", " ")
            .trim()
            .toLowerCase();
}
