package com.acfc.automation.config;

public class ExecutionArgumentReader {

    public static ExecutionContext loadFromArguments() {

        ExecutionContext ctx = new ExecutionContext();

        ctx.setFramework(required("TA_FRAMEWORK"));
        ctx.setSite(required("TA_SITE"));
        ctx.setChangeId(required("TA_CHANGEID"));
        ctx.setProduct(required("TA_PRODUCT"));
        ctx.setApplication(required("TA_APPLICATION"));
        ctx.setEnvType(required("TA_ENVTYPE"));
        ctx.setRelease(required("TA_RELEASE"));
        ctx.setTestSuiteType(required("TA_TESTSUITE_TYPE"));
        ctx.setRepository(required("TA_REPOSITORY"));
        ctx.setBuildGitBranch(required("TA_BUILD_GIT_BRANCH"));
        ctx.setJob(required("TA_JOB"));
        ctx.setStatusFile(required("TA_STATUS_FILE"));

        return ctx;
    }

    private static String required(String key) {
        String value = System.getProperty(key);

        if (value == null || value.trim().isEmpty()) {
            throw new IllegalArgumentException(
                "Missing required argument: -D" + key + "=<value>"
            );
        }

        return value.trim();
    }
}
