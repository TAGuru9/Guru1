package com.acfc.automation.config;

import java.nio.file.Path;
import java.nio.file.Paths;

public final class FrameworkConfig {

    private FrameworkConfig() {
    }

    public static String getProperty(String key) {
        String sysValue = System.getProperty(key);
        if (sysValue != null && !sysValue.trim().isBlank()) {
            return sysValue.trim();
        }

        String fileValue = PropertiesLoader.get(key);
        if (fileValue != null && !fileValue.trim().isBlank()) {
            return fileValue.trim();
        }

        return null;
    }

    public static String getProperty(String key, String defaultValue) {
        String value = getProperty(key);
        return (value == null || value.isBlank()) ? defaultValue : value;
    }

    public static String env() {
        return getProperty("env", "dev");
    }

    public static String projectName() {
        return getProperty("project", "NA");
    }

    public static String site() {
        return getProperty("site", "automation");
    }

    public static String release() {
        return getProperty("release", "NA");
    }

    public static String repository() {
        return getProperty("repository", "NA");
    }

    public static String gitBranch() {
        return getProperty("gitBranch", "NA");
    }

    public static String buildUrl() {
        return getProperty("buildUrl", "NA");
    }

    public static String suite() {
        return getProperty("suite", "");
    }

    public static String type() {
        return getProperty("type", "");
    }

    public static String ids() {
        return getProperty("ids", "");
    }

    public static String names() {
        return getProperty("names", "");
    }

    public static String tcFile() {
        return getProperty("tcFile", "");
    }

    public static Path sharedContextFile() {
        return Paths.get(getProperty("shared.context.file", "build/shared-context.json"));
    }
}
