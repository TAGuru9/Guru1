package com.acfc.automation.context;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.util.JacksonUtil;

import java.nio.file.Files;
import java.nio.file.Path;
import java.util.LinkedHashMap;
import java.util.Map;

public class SharedContextManager {

    private static final Map<String, Object> CACHE = new LinkedHashMap<>();
    private static boolean loaded = false;

    private SharedContextManager() {
    }

    private static synchronized void loadIfNeeded() {
        if (loaded) {
            return;
        }

        try {
            Path file = FrameworkConfig.sharedContextFile();

            if (Files.exists(file)) {
                Map<String, Object> map = JacksonUtil.mapper()
                        .readValue(file.toFile(), LinkedHashMap.class);
                CACHE.putAll(map);
            }

            loaded = true;

        } catch (Exception e) {
            throw new RuntimeException("Failed to load shared context", e);
        }
    }

    private static synchronized void persist() {
        try {
            Path file = FrameworkConfig.sharedContextFile();
            if (file.getParent() != null) {
                Files.createDirectories(file.getParent());
            }
            JacksonUtil.mapper().writerWithDefaultPrettyPrinter().writeValue(file.toFile(), CACHE);
        } catch (Exception e) {
            throw new RuntimeException("Failed to persist shared context", e);
        }
    }

    public static synchronized void put(String key, Object value) {
        loadIfNeeded();
        CACHE.put(key, value);
        persist();
    }

    public static synchronized Object get(String key) {
        loadIfNeeded();
        return CACHE.get(key);
    }

    public static synchronized String getAsString(String key) {
        loadIfNeeded();
        Object value = CACHE.get(key);
        return value == null ? null : String.valueOf(value);
    }

    public static synchronized Map<String, Object> snapshot() {
        loadIfNeeded();
        return new LinkedHashMap<>(CACHE);
    }

    public static synchronized void clear() {
        CACHE.clear();
        loaded = true;
        persist();
    }
}
