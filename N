public static void writeSuiteSummaryKpi(String project,
                                        String suite,
                                        String type,
                                        String env,
                                        int total,
                                        int passed,
                                        int failed,
                                        int skipped,
                                        long durationMs,
                                        String reportPath) {
    initRun();

    try {
        Path dir;

        if (reportPath != null && !reportPath.isBlank()) {
            Path reportFile = Paths.get(reportPath);
            Path reportDir = reportFile.getParent(); // .../build/reports/extent/...
            Path buildDir = reportDir;

            while (buildDir != null && !buildDir.getFileName().toString().equalsIgnoreCase("build")) {
                buildDir = buildDir.getParent();
            }

            if (buildDir != null) {
                dir = buildDir.resolve("reports").resolve("kpi");
            } else {
                dir = Paths.get("build", "reports", "kpi");
            }
        } else {
            dir = Paths.get("build", "reports", "kpi");
        }

        Files.createDirectories(dir);

        Path file = dir.resolve("kpi_summary_" + runId + ".csv");
        boolean newFile = !Files.exists(file);

        synchronized (LOCK) {
            try (PrintWriter writer = new PrintWriter(new FileWriter(file.toFile(), true))) {
                if (newFile) {
                    writer.println("runId,project,suite,type,env,total,passed,failed,skipped,durationMs,reportPath");
                }

                writer.println(csv(runId) + ","
                        + csv(project) + ","
                        + csv(suite) + ","
                        + csv(type) + ","
                        + csv(env) + ","
                        + total + ","
                        + passed + ","
                        + failed + ","
                        + skipped + ","
                        + durationMs + ","
                        + csv(reportPath));
            }
        }

        System.out.println("KPI suite summary written to: " + file.toAbsolutePath());
    } catch (Exception e) {
        System.out.println("Failed to write suite KPI summary: " + e.getMessage());
    }
}
