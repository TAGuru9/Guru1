package com.acfc.automation.data;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.model.TestCase;
import com.fasterxml.jackson.databind.DeserializationFeature;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.List;
import java.util.stream.Stream;

public final class TestCaseLoader {

    private static final ObjectMapper MAPPER = new ObjectMapper()
            .configure(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES, false);

    private TestCaseLoader() {
    }

    private static String getProject() {
        String project = System.getProperty("project");
        if (project != null && !project.trim().isBlank()) {
            return project.trim();
        }
        return FrameworkConfig.getProperty("project", "").trim();
    }

    public static List<TestCase> parse(String filePath) {
        try {
            Path path = resolveTestcasePath(filePath);

            if (!Files.exists(path)) {
                throw new RuntimeException("Test case file not found: " + filePath);
            }

            System.out.println("Parsing testcase from: " + path.toAbsolutePath());

            TestCase testCase = MAPPER.readValue(path.toFile(), TestCase.class);

            List<TestCase> list = new ArrayList<>();
            list.add(testCase);
            return list;

        } catch (Exception e) {
            throw new RuntimeException("Failed to load test case: " + filePath, e);
        }
    }

    public static List<TestCase> loadAll() {
        try {
            List<TestCase> cases = new ArrayList<>();

            Path dir = resolveTestcaseDirectory();
            if (dir == null) {
                System.out.println("No testcase directory found.");
                return cases;
            }

            System.out.println("Loading testcases from: " + dir.toAbsolutePath());

            try (Stream<Path> stream = Files.list(dir)) {
                List<Path> files = stream
                        .filter(Files::isRegularFile)
                        .filter(p -> p.toString().toLowerCase().endsWith(".json"))
                        .sorted(Comparator.comparing(Path::toString))
                        .toList();

                for (Path file : files) {
                    try {
                        System.out.println("Reading testcase file: " + file.getFileName());
                        TestCase testCase = MAPPER.readValue(file.toFile(), TestCase.class);
                        cases.add(testCase);
                    } catch (Exception e) {
                        System.out.println("Skipping invalid testcase file: "
                                + file.getFileName() + " -> " + e.getMessage());
                    }
                }
            }

            System.out.println("Loaded test cases count: " + cases.size());
            return cases;

        } catch (Exception e) {
            throw new RuntimeException("Failed to load test cases", e);
        }
    }

    private static Path resolveTestcasePath(String filePath) {
        String project = getProject();

        List<Path> candidates = new ArrayList<>();

        // 1. Exact path as provided
        candidates.add(Paths.get(filePath));

        // 2. Relative to current module resources
        candidates.add(Paths.get("src", "test", "resources").resolve(filePath).normalize());

        // 3. Relative to provided project resources
        if (!project.isEmpty()) {
            candidates.add(Paths.get(project, "src", "test", "resources").resolve(filePath).normalize());
        }

        for (Path candidate : candidates) {
            if (Files.exists(candidate)) {
                return candidate;
            }
        }

        // Return best guess for logging/error message
        return candidates.get(candidates.size() - 1);
    }

    private static Path resolveTestcaseDirectory() {
        String project = getProject();

        List<Path> candidateDirs = new ArrayList<>();

        // 1. Current module
        candidateDirs.add(Paths.get("src", "test", "resources", "testcases"));

        // 2. Passed/configured project module
        if (!project.isEmpty()) {
            candidateDirs.add(Paths.get(project, "src", "test", "resources", "testcases"));
        }

        for (Path candidate : candidateDirs) {
            if (Files.exists(candidate)) {
                return candidate;
            }
        }

        return null;
    }
}
