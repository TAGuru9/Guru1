package com.acfc.automation.util;

import java.io.BufferedReader;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

public class TestDataReader {

    private TestDataReader() {
    }

    public static Path resolve(String filePath) {
        if (filePath == null || filePath.isBlank()) {
            throw new IllegalArgumentException("File path is blank");
        }

        Path directPath = Paths.get(filePath);
        if (Files.exists(directPath)) {
            return directPath.toAbsolutePath().normalize();
        }

        Path resourcePath = Paths.get("src", "test", "resources")
                .resolve(filePath)
                .normalize();

        if (Files.exists(resourcePath)) {
            return resourcePath.toAbsolutePath().normalize();
        }

        throw new RuntimeException(
                "Test data file not found. Checked: " + directPath + " and " + resourcePath
        );
    }

    public static String getFileType(String filePath) {
        int idx = filePath.lastIndexOf('.');
        if (idx <= 0 || idx == filePath.length() - 1) {
            throw new IllegalArgumentException("Invalid file path: " + filePath);
        }
        return filePath.substring(idx + 1).toLowerCase();
    }

    public static List<Map<String, String>> readData(String filePath, String delimiter) {
        Path path = resolve(filePath);
        String fileType = getFileType(path.toString());

        switch (fileType) {
            case "csv":
                return readDelimitedFile(path, normalizeDelimiter(delimiter));
            case "txt":
                return readDelimitedFile(path, normalizeDelimiter(delimiter));
            default:
                throw new RuntimeException("Unsupported test data file type: " + fileType);
        }
    }

    private static List<Map<String, String>> readDelimitedFile(Path path, String delimiter) {
        try (BufferedReader reader = Files.newBufferedReader(path)) {
            List<Map<String, String>> records = new ArrayList<>();

            String headerLine = reader.readLine();
            if (headerLine == null || headerLine.isBlank()) {
                return records;
            }

            String[] headers = split(headerLine, delimiter);

            String line;
            while ((line = reader.readLine()) != null) {
                if (line.trim().isEmpty()) {
                    continue;
                }

                String[] values = split(line, delimiter);
                Map<String, String> row = new LinkedHashMap<>();

                for (int i = 0; i < headers.length; i++) {
                    String key = headers[i] == null ? "" : headers[i].trim();
                    String value = i < values.length ? values[i].trim() : "";
                    row.put(key, value);
                }

                records.add(row);
            }

            return records;

        } catch (Exception e) {
            throw new RuntimeException("Failed to read test data from: " + path, e);
        }
    }

    private static String[] split(String line, String delimiter) {
        return line.split(java.util.regex.Pattern.quote(delimiter), -1);
    }

    private static String normalizeDelimiter(String delimiter) {
        if (delimiter == null || delimiter.isBlank()) {
            return ",";
        }

        String trimmed = delimiter.trim();

        if ("tab".equalsIgnoreCase(trimmed) || "\\t".equals(trimmed)) {
            return "\t";
        }

        return trimmed;
    }
}
