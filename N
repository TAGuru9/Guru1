package com.acfc.automation.payload;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.util.FileUtil;
import com.acfc.automation.util.PlaceholderResolver;

import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.List;
import java.util.Map;

public class PayloadBuilder {

    private PayloadBuilder() {
    }

    private static String getProject() {
        String project = System.getProperty("project");
        if (project != null && !project.trim().isBlank()) {
            return project.trim();
        }
        return FrameworkConfig.getProperty("project", "").trim();
    }

    private static Path resolveResourcePath(String filePath) {
        if (filePath == null || filePath.isBlank()) {
            throw new IllegalArgumentException("Resource path is blank");
        }

        String trimmed = filePath.trim();
        String project = getProject();

        List<Path> candidates = new ArrayList<>();

        // 1. Use exactly what was passed
        candidates.add(Paths.get(trimmed));

        // 2. Current module resources
        candidates.add(Paths.get("src", "test", "resources").resolve(trimmed).normalize());

        // 3. Selected project resources, only if not already project-prefixed
        if (!project.isEmpty() && !trimmed.startsWith(project + "/") && !trimmed.startsWith(project + "\\")) {
            candidates.add(Paths.get(project, "src", "test", "resources").resolve(trimmed).normalize());
        }

        // 4. If caller already passed project-prefixed path, keep it as-is
        if (!project.isEmpty() && (trimmed.startsWith(project + "/") || trimmed.startsWith(project + "\\"))) {
            candidates.add(Paths.get(trimmed).normalize());
        }

        for (Path candidate : candidates) {
            Path absolute = candidate.toAbsolutePath().normalize();
            System.out.println("Checking payload/template path: " + absolute);
            if (Files.exists(absolute)) {
                return absolute;
            }
        }

        throw new RuntimeException("File not found. Checked direct/relative/resources paths for: " + filePath);
    }

    public static String build(String inlineBody,
                               String bodyFile,
                               String requestTemplate,
                               Map<String, Object> context,
                               String testId) {
        try {
            String content = null;

            if (inlineBody != null && !inlineBody.isBlank()) {
                content = inlineBody;

            } else if (bodyFile != null && !bodyFile.isBlank()) {
                Path bodyPath = resolveResourcePath(bodyFile);
                content = FileUtil.read(bodyPath);

            } else if (requestTemplate != null && !requestTemplate.isBlank()) {
                Path templatePath = resolveResourcePath(requestTemplate);
                content = FileUtil.read(templatePath);
            }

            if (content == null) {
                return null;
            }

            String resolved = PlaceholderResolver.resolve(content, context);

            Path outDir = Paths.get("build", "generated-payloads");
            Files.createDirectories(outDir);

            String extension = requestTemplate != null && requestTemplate.toLowerCase().endsWith(".xml") ? ".xml" : ".json";
            Path out = outDir.resolve(testId + "-request" + extension);
            FileUtil.write(out, resolved);

            return resolved;

        } catch (Exception e) {
            throw new RuntimeException("Failed to build payload for test: " + testId, e);
        }
    }
}
