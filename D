package com.acfc.automation.report.kpi;

import java.util.Map;

public class KpiRuntimeParams {

    private static Map<String, String> parsedArgs;

    private KpiRuntimeParams() {
    }

    private static Map<String, String> args() {
        if (parsedArgs == null) {
            parsedArgs = KpiArgsParser.parse(
                    FrameworkConfig.getProperty("kpiArgs", "")
            );
        }
        return parsedArgs;
    }

    public static String framework() {
        return KpiArgsParser.get(args(), "framework", "PepperAPI");
    }

    public static String site() {
        return KpiArgsParser.get(args(), "site", "automation");
    }

    public static String changeId() {
        return KpiArgsParser.get(args(), "changeId", "NA");
    }

    public static String product() {
        return KpiArgsParser.get(args(), "product", "NA");
    }

    public static String application() {
        return KpiArgsParser.get(args(), "application", FrameworkConfig.projectName());
    }

    public static String envType() {
        return KpiArgsParser.get(args(), "env", FrameworkConfig.env());
    }

    public static String release() {
        return KpiArgsParser.get(args(), "release", "NA");
    }

    public static String testSuiteType() {
        return KpiArgsParser.get(
                args(),
                "testSuiteType",
                FrameworkConfig.getProperty("type", "NA")
        );
    }

    public static String repository() {
        return KpiArgsParser.get(args(), "repository", "NA");
    }

    public static String gitBranch() {
        return KpiArgsParser.get(args(), "gitBranch", "NA");
    }

    public static String userId() {
        return KpiArgsParser.get(
                args(),
                "userId",
                System.getProperty("user.name", "NA")
        );
    }

    public static String buildUrl() {
        return KpiArgsParser.get(args(), "buildUrl", "NA");
    }

    public static String executor() {
        return KpiArgsParser.get(
                args(),
                "executor",
                System.getProperty("user.name", "NA")
        );
    }

    public static String executionSource() {
        String buildUrl = System.getenv("BUILD_URL");
        return KpiArgsParser.get(
                args(),
                "executionSource",
                !safe(buildUrl).equals("NA") ? "Jenkins" : "Local"
        );
    }

    public static String vm() {
        return KpiArgsParser.get(
                args(),
                "vm",
                firstNonBlank(
                        System.getenv("COMPUTERNAME"),
                        System.getenv("HOSTNAME"),
                        "NA"
                )
        );
    }

    public static String testSuiteArgs(String reportPath) {
        String userId = KpiArgsParser.get(
                args(),
                "userId",
                System.getProperty("user.name", "NA")
        );

        String password = KpiArgsParser.get(args(), "password", "NA");
        if (!"NA".equalsIgnoreCase(password)) {
            password = "*******";
        }

        String reportFile = extractReportName(reportPath);

        return "userId=" + safe(userId)
                + ",password=" + safe(password)
                + ",report=" + safe(reportFile);
    }

    private static String extractReportName(String path) {
        if (path == null || path.isBlank()) {
            return "NA";
        }

        int idx = path.lastIndexOf('/');
        if (idx == -1) {
            idx = path.lastIndexOf('\\');
        }

        return idx != -1 ? path.substring(idx + 1) : path;
    }

    private static String firstNonBlank(String... values) {
        if (values == null) {
            return "NA";
        }

        for (String v : values) {
            if (v != null && !v.isBlank()) {
                return v.trim();
            }
        }
        return "NA";
    }

    private static String safe(String value) {
        return value == null || value.isBlank() ? "NA" : value.trim();
    }
}
