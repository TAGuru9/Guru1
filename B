package com.acfc.automation.data;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.model.TestCase;
import com.acfc.automation.util.JacksonUtil;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.List;

public class TestCaseLoader {

    private TestCaseLoader() {
    }

    public static List<TestCase> parse(String filePath) {
        try {
            List<TestCase> cases = new ArrayList<>();

            Path path = FrameworkConfig.testResourcesDir().resolve(filePath);

            if (!Files.exists(path)) {
                throw new RuntimeException("Test case file not found: " + path);
            }

            TestCase testCase = JacksonUtil.mapper().readValue(path.toFile(), TestCase.class);
            cases.add(testCase);

            return cases;

        } catch (Exception e) {
            throw new RuntimeException("Failed to parse test case file: " + filePath, e);
        }
    }

    public static List<TestCase> loadAll() {
        try {
            List<TestCase> cases = new ArrayList<>();

            Path dir = FrameworkConfig.testResourcesDir().resolve("testcases");

            if (!Files.exists(dir)) {
                return cases;
            }

            Files.walk(dir)
                    .filter(Files::isRegularFile)
                    .filter(p -> p.toString().endsWith(".json"))
                    .sorted()
                    .forEach(p -> {
                        try {
                            TestCase testCase = JacksonUtil.mapper().readValue(p.toFile(), TestCase.class);
                            cases.add(testCase);
                        } catch (Exception e) {
                            throw new RuntimeException("Failed to load test case: " + p, e);
                        }
                    });

            return cases;

        } catch (IOException e) {
            throw new RuntimeException("Failed to load all test cases", e);
        }
    }
}
