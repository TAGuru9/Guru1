Write-StepLog "Facets automation started"

if (($RunAll.ToUpper() -ne "Y") -and [string]::IsNullOrWhiteSpace($RunModule)) {
    $RunModule = Show-ModulePopup

    if ([string]::IsNullOrWhiteSpace($RunModule)) {
        [System.Windows.Forms.MessageBox]::Show(
            "No option selected. Script will stop.",
            "Facets Automation"
        )
        Write-StepLog "No option selected. Script stopped."
        exit
    }
}

if ($RunAll.ToUpper() -eq "Y") {
    $RunModule = "All"
}

Write-StepLog "Selected module: $RunModule"
