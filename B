Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# -----------------------------
# Global variables
# -----------------------------
$RunAll    = "N"
$RunModule = ""

$BaseFolder       = "C:\Temp\FacetsAutomation"
$RunTimeStamp     = Get-Date -Format "yyyyMMdd_HHmmss"
$RunFolder        = Join-Path $BaseFolder $RunTimeStamp
$ScreenshotFolder = Join-Path $RunFolder "Screenshots"
$LogFile          = Join-Path $RunFolder "ExecutionLog.txt"

# -----------------------------
# Initialize folders
# -----------------------------
function Initialize-RunFolders {
    if (-not (Test-Path $BaseFolder)) {
        New-Item -ItemType Directory -Path $BaseFolder -Force | Out-Null
    }

    if (-not (Test-Path $RunFolder)) {
        New-Item -ItemType Directory -Path $RunFolder -Force | Out-Null
    }

    if (-not (Test-Path $ScreenshotFolder)) {
        New-Item -ItemType Directory -Path $ScreenshotFolder -Force | Out-Null
    }
}

# -----------------------------
# Sleep helper
# -----------------------------
function TA-Sleep {
    param(
        [int]$Seconds = 2
    )
    Start-Sleep -Seconds $Seconds
}

# -----------------------------
# Logging
# -----------------------------
function Write-StepLog {
    param(
        [string]$Message
    )

    $timeStamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "$timeStamp - $Message"

    Add-Content -Path $LogFile -Value $line
    Write-Host $line
}

# -----------------------------
# Screenshot
# -----------------------------
function New-Screenshot {
    param(
        [string]$StepName = "Step"
    )

    try {
        $bounds = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
        $bitmap = New-Object System.Drawing.Bitmap $bounds.Width, $bounds.Height
        $graphics = [System.Drawing.Graphics]::FromImage($bitmap)

        $graphics.CopyFromScreen(
            $bounds.Location,
            [System.Drawing.Point]::Empty,
            $bounds.Size
        )

        $safeStepName = $StepName -replace '[\\/:*?"<>|]', '_'
        $fileName = "{0}_{1}.png" -f (Get-Date -Format "yyyyMMdd_HHmmss_fff"), $safeStepName
        $filePath = Join-Path $ScreenshotFolder $fileName

        $bitmap.Save($filePath, [System.Drawing.Imaging.ImageFormat]::Png)

        $graphics.Dispose()
        $bitmap.Dispose()

        Write-StepLog "Screenshot saved: $filePath"
        return $filePath
    }
    catch {
        Write-StepLog "Screenshot failed: $($_.Exception.Message)"
    }
}

# -----------------------------
# Common step wrapper
# -----------------------------
function Invoke-Step {
    param(
        [string]$StepName,
        [scriptblock]$Action
    )

    try {
        Write-StepLog "STARTED: $StepName"
        & $Action
        TA-Sleep -Seconds 1
        New-Screenshot -StepName $StepName | Out-Null
        Write-StepLog "PASSED: $StepName"
    }
    catch {
        Write-StepLog "FAILED: $StepName - $($_.Exception.Message)"
        New-Screenshot -StepName "${StepName}_FAILED" | Out-Null
        throw
    }
}

