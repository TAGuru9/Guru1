private String getExpectedMessage(TestCase testCase, Map<String, String> currentRow) {

    if (testCase.getExpectedMessageField() != null &&
        !testCase.getExpectedMessageField().isBlank()) {

        String value = currentRow.get(testCase.getExpectedMessageField());
        return value == null ? "" : value.trim();
    }

    if (testCase.getExpectedBodyContains() != null &&
        !testCase.getExpectedBodyContains().isEmpty()) {

        return testCase.getExpectedBodyContains().get(0);
    }

    return "";
}
