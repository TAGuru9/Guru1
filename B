int expectedStatus = getExpectedStatus(testCase, currentRow);
String expectedMessage = getExpectedMessage(testCase, currentRow);

int actualStatus = response.getStatusCode();
String responseBody = response.getBody().asString();

boolean isNegative = "negative".equalsIgnoreCase(testCase.getType());

extentTest.info("Expected Status: " + expectedStatus);
extentTest.info("Actual Status: " + actualStatus);

extentTest.info("Expected Message: " + expectedMessage);
extentTest.info("Response Body: " + responseBody);

// ===== STATUS VALIDATION =====
if (actualStatus == expectedStatus) {
    extentTest.pass("✅ Status matched: " + actualStatus);
} else {
    extentTest.fail("❌ Status mismatch. Expected: " + expectedStatus + " but got: " + actualStatus);
    finalStatus = "FAIL";
}

// ===== MESSAGE VALIDATION =====
if (expectedMessage != null && !expectedMessage.isBlank()) {
    if (responseBody.contains(expectedMessage)) {
        extentTest.pass("✅ Message validated: " + expectedMessage);
    } else {
        extentTest.fail("❌ Expected message not found: " + expectedMessage);
        finalStatus = "FAIL";
    }
}

// ===== NEGATIVE TEST HANDLING =====
if (isNegative) {
    if (actualStatus == expectedStatus) {
        extentTest.pass("✅ Negative test passed (Expected failure received)");
    } else {
        extentTest.fail("❌ Negative test failed. Expected error but got success");
        finalStatus = "FAIL";
    }
}

