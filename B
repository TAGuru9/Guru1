private String buildManualQaMessage(int expectedStatus, int actualStatus) {

    if (expectedStatus == actualStatus) {
        return "Verify UI/API behavior matches expected scenario.";
    }

    switch (actualStatus) {
        case 400:
            return "Check missing/invalid input fields.";
        case 401:
            return "Check authentication token.";
        case 403:
            return "Check authorization/permissions.";
        case 404:
            return "Check endpoint or resource.";
        case 500:
            return "Server error → raise defect.";
        case 503:
        case 504:
            return "Service unavailable → retry or check environment.";
        default:
            return "Unexpected response → investigate logs.";
    }
}
