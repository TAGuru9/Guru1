@TestFactory
public List<DynamicTest> execution() throws Exception {
    SummaryTracker.startSuite();
    ExecutionResultStore.clear();

    List<TestCase> allCases = TestCaseLoader.loadAll();
    List<TestCase> selectedCases = selectCases(allCases);

    if (selectedCases.isEmpty()) {
        throw new IllegalArgumentException("No matching test cases found");
    }

    List<DynamicTest> tests = new ArrayList<>();

    for (TestCase testCase : selectedCases) {
        String dataFile = resolveDataFile(testCase);
        String delimiter = resolveDelimiter(testCase);
        boolean loopEnabled = isLoopEnabled(testCase);

        if (loopEnabled && dataFile != null && !dataFile.isBlank()) {
            List<Map<String, String>> records = TestDataReader.readData(dataFile, delimiter);

            for (int i = 0; i < records.size(); i++) {
                int iteration = i + 1;
                Map<String, String> record = records.get(i);

                tests.add(DynamicTest.dynamicTest(
                        testCase.getId() + " - Iteration " + iteration,
                        () -> executeLoopIteration(testCase, record, iteration)
                ));
            }
        } else {
            tests.add(DynamicTest.dynamicTest(
                    safe(testCase.getId()) + " - " + safe(testCase.getName()),
                    () -> executeSingle(testCase)
            ));
        }
    }

    return tests;
}
