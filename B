for (Map<String, String> currentRow : csvData) {

    // ===== Build request =====
    String requestBody = buildRequest(testCase, currentRow);

    Response response = RestAssured.given()
            .headers(headers)
            .body(requestBody)
            .post(url);

    // ===== Read CSV expected =====
    int expectedStatus = getExpectedStatus(testCase, currentRow);
    String expectedMessage = getExpectedMessage(testCase, currentRow);

    // ===== Actual =====
    int actualStatus = response.getStatusCode();
    String responseBody = response.getBody().asString();

    // ===== Validation =====
    if (actualStatus != expectedStatus) {
        throw new RuntimeException("Status mismatch: expected "
                + expectedStatus + " but got " + actualStatus);
    }

    if (expectedMessage != null && !expectedMessage.isBlank()) {
        if (!responseBody.contains(expectedMessage)) {
            throw new RuntimeException("Expected message not found: " + expectedMessage);
        }
    }

    System.out.println("Row PASSED: " + currentRow);
}
