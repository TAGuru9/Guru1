package com.acfc.automation.util;

import com.acfc.automation.config.FrameworkConfig;

import java.io.BufferedReader;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Pattern;

public class TestDataReader {

    private TestDataReader() {
    }

    public static List<Map<String, String>> readData(String filePath, String delimiter) throws IOException {
        Path resolvedPath = resolvePath(filePath);

        String fileType = getFileType(resolvedPath.getFileName().toString());

        if ("csv".equalsIgnoreCase(fileType)) {
            return readDelimitedFile(resolvedPath, ",");
        } else if ("txt".equalsIgnoreCase(fileType)) {
            String actualDelimiter = (delimiter == null || delimiter.isBlank()) ? "|" : delimiter;
            return readDelimitedFile(resolvedPath, actualDelimiter);
        } else {
            throw new IllegalArgumentException("Unsupported file type: " + fileType);
        }
    }

    private static Path resolvePath(String filePath) {
        if (filePath == null || filePath.isBlank()) {
            throw new IllegalArgumentException("Invalid file path: " + filePath);
        }

        Path directPath = Path.of(filePath);
        if (Files.exists(directPath)) {
            return directPath;
        }

        Path resourcePath = FrameworkConfig.testResourcesDir().resolve(filePath);
        if (Files.exists(resourcePath)) {
            return resourcePath;
        }

        throw new RuntimeException("Test data file not found. Checked: " + directPath + " and " + resourcePath);
    }

    private static String getFileType(String filePath) {
        int idx = filePath.lastIndexOf('.');
        if (idx < 0 || idx == filePath.length() - 1) {
            throw new IllegalArgumentException("Invalid file path: " + filePath);
        }
        return filePath.substring(idx + 1).toLowerCase();
    }

    private static List<Map<String, String>> readDelimitedFile(Path path, String delimiter) throws IOException {
        List<Map<String, String>> records = new ArrayList<>();

        try (BufferedReader br = Files.newBufferedReader(path)) {
            String headerLine = br.readLine();
            if (headerLine == null || headerLine.isBlank()) {
                return records;
            }

            String[] headers = headerLine.split(Pattern.quote(delimiter), -1);

            String line;
            while ((line = br.readLine()) != null) {
                if (line.trim().isEmpty()) {
                    continue;
                }

                String[] values = line.split(Pattern.quote(delimiter), -1);
                Map<String, String> row = new LinkedHashMap<>();

                for (int i = 0; i < headers.length; i++) {
                    String key = headers[i].trim();
                    String value = i < values.length ? values[i].trim() : "";
                    row.put(key, value);
                }

                records.add(row);
            }
        }

        return records;
    }
}
