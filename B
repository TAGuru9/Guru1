package com.acfc.automation.report;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.model.TestCase;

// Use your actual Peppermill imports here.
// Let IntelliJ auto-import after the dependency resolves.
import com.amerihealthcaritas.qa.peppermill.PeppermillParameter;
import com.amerihealthcaritas.qa.peppermill.Report;

public class PeppermillKpiReporter {

    private static final Object LOCK = new Object();
    private static Report report;

    private PeppermillKpiReporter() {
    }

    public static void init() {
        synchronized (LOCK) {
            if (report == null) {
                report = new Report();
            }
        }
    }

    public static void writeTestcaseEntry(TestCase testCase,
                                          String status,
                                          String reportPath,
                                          String executionArgs,
                                          String errorMessage) {
        init();

        synchronized (LOCK) {
            try {
                report.WriteKpiEntry(
                        PeppermillParameter.TA_FRAMEWORK, "PepperAPI",
                        PeppermillParameter.TA_PRODUCT, safe(testCase.getProject()),
                        PeppermillParameter.TA_CHANGEID, safe(System.getProperty("changeId")),
                        PeppermillParameter.TA_APPLICATION, safe(testCase.getSuite()),
                        PeppermillParameter.TA_ENVTYPE, safe(System.getProperty("env", FrameworkConfig.env())),
                        PeppermillParameter.TA_RELEASE, safe(System.getProperty("release")),
                        PeppermillParameter.TA_TESTSUITE_TYPE, safe(testCase.getType()),
                        PeppermillParameter.TA_TESTSUITE_ARGS, safe(executionArgs),
                        PeppermillParameter.TA_TESTRESULT, safe(status),
                        PeppermillParameter.TA_TESTNAME, safe(testCase.getId()) + " - " + safe(testCase.getName()),
                        PeppermillParameter.TA_REPORTPATH, safe(reportPath),
                        PeppermillParameter.TA_ERRORMSG, safe(errorMessage)
                );
            } catch (Exception e) {
                System.out.println("Peppermill testcase KPI write failed: " + e.getMessage());
            }
        }
    }

    public static void writeSuiteSummary(int passed, int failed, int skipped) {
        init();

        synchronized (LOCK) {
            try {
                report.setTestCounts(passed, failed, skipped);
            } catch (Exception e) {
                System.out.println("Peppermill summary write failed: " + e.getMessage());
            }
        }
    }

    private static String safe(String value) {
        return value == null || value.isBlank() ? "NA" : value.trim();
    }
}
