private String getBaseUrl(TestCase testCase) {
    String key = testCase.getBaseUrlProperty();
    if (key == null || key.isBlank()) {
        throw new IllegalArgumentException("baseUrlProperty is missing in test case: " + testCase.getId());
    }

    String baseUrl = PropertiesLoader.getRequired(key);

    System.out.println("DEBUG baseUrlProperty key : " + key);
    System.out.println("DEBUG resolved baseUrl    : " + baseUrl);

    return baseUrl;
}
