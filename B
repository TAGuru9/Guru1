package com.acfc.automation.model;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class ExecutionResult {

    private final Map<String, Object> extractedValues = new HashMap<>();
    private final List<Object> validationDetails = new ArrayList<>();

    private final String project;
    private final String id;
    private final String name;
    private final String method;
    private final String type;
    private final String suite;
    private final int expectedStatus;
    private final int actualStatus;
    private final String status;
    private final long durationMs;

    public ExecutionResult(String project,
                           String id,
                           String name,
                           String method,
                           String type,
                           String suite,
                           int expectedStatus,
                           int actualStatus,
                           String status,
                           long durationMs) {
        this.project = project;
        this.id = id;
        this.name = name;
        this.method = method;
        this.type = type;
        this.suite = suite;
        this.expectedStatus = expectedStatus;
        this.actualStatus = actualStatus;
        this.status = status;
        this.durationMs = durationMs;
    }

    public String getProject() {
        return project;
    }

    public String getId() {
        return id;
    }

    public String getName() {
        return name;
    }

    public String getMethod() {
        return method;
    }

    public String getType() {
        return type;
    }

    public String getSuite() {
        return suite;
    }

    public int getExpectedStatus() {
        return expectedStatus;
    }

    public int getActualStatus() {
        return actualStatus;
    }

    public String getStatus() {
        return status;
    }

    public long getDurationMs() {
        return durationMs;
    }

    public Map<String, Object> getExtractedValues() {
        return extractedValues;
    }

    public List<Object> getValidationDetails() {
        return validationDetails;
    }
}
