package com.acfc.automation.report;

import com.acfc.automation.model.ExecutionResult;

import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

public final class ExecutionResultStore {

    private static final List<ExecutionResult> RESULTS = new ArrayList<>();

    private ExecutionResultStore() {
    }

    public static void add(ExecutionResult result) {
        if (result != null) {
            RESULTS.add(result);
        }
    }

    public static List<ExecutionResult> getAll() {
        return Collections.unmodifiableList(RESULTS);
    }

    public static void clear() {
        RESULTS.clear();
    }
}
