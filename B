package com.acfc.automation.db;

import com.acfc.automation.context.ExecutionContext;
import com.acfc.automation.model.DBQuery;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSetMetaData;
import java.util.Collections;
import java.util.LinkedHashMap;
import java.util.Map;

public class DbClient {

    public Map<String, Object> executeSingleRow(DBQuery query, Map<String, Object> context) {
        String prefix = "db." + query.getConnection() + ".";

        String url = System.getProperty(prefix + "url");
        String user = System.getProperty(prefix + "user");
        String password = System.getProperty(prefix + "password");
        String driver = System.getProperty(prefix + "driver");

        if (url == null || url.isBlank()) {
            throw new IllegalArgumentException("Missing DB property: " + prefix + "url");
        }

        try {
            if (driver != null && !driver.isBlank()) {
                Class.forName(driver);
            }

            try (Connection conn = DriverManager.getConnection(url, user, password);
                 PreparedStatement st = conn.prepareStatement(query.getSql())) {

                Map<String, String> params = query.getParams();
                if (params != null && !params.isEmpty()) {
                    int index = 1;
                    for (Map.Entry<String, String> entry : params.entrySet()) {
                        String value = entry.getValue();
                        if (value != null && value.startsWith("${") && value.endsWith("}")) {
                            String key = value.substring(2, value.length() - 1).trim();
                            Object ctxVal = ExecutionContext.get(key);
                            st.setObject(index++, ctxVal);
                        } else {
                            st.setObject(index++, value);
                        }
                    }
                }

                try (java.sql.ResultSet rs = st.executeQuery()) {
                    if (!rs.next()) {
                        return Collections.emptyMap();
                    }

                    ResultSetMetaData meta = rs.getMetaData();
                    Map<String, Object> row = new LinkedHashMap<>();

                    for (int i = 1; i <= meta.getColumnCount(); i++) {
                        row.put(meta.getColumnLabel(i), rs.getObject(i));
                    }

                    return row;
                }
            }
        } catch (Exception e) {
            throw new RuntimeException("DB query execution failed", e);
        }
    }
}
