param(
    [string]$RunAll = "Y",
    [string]$RunModule = ""
)

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

function Show-ModulePopup {
    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Select Module"
    $form.Size = New-Object System.Drawing.Size(320,180)
    $form.StartPosition = "CenterScreen"
    $form.TopMost = $true

    $label = New-Object System.Windows.Forms.Label
    $label.Text = "Choose one option:"
    $label.AutoSize = $true
    $label.Location = New-Object System.Drawing.Point(20,20)

    $btnProvider = New-Object System.Windows.Forms.Button
    $btnProvider.Text = "Provider"
    $btnProvider.Size = New-Object System.Drawing.Size(80,35)
    $btnProvider.Location = New-Object System.Drawing.Point(20,60)

    $btnClaims = New-Object System.Windows.Forms.Button
    $btnClaims.Text = "Claims"
    $btnClaims.Size = New-Object System.Drawing.Size(80,35)
    $btnClaims.Location = New-Object System.Drawing.Point(110,60)

    $btnMember = New-Object System.Windows.Forms.Button
    $btnMember.Text = "Member"
    $btnMember.Size = New-Object System.Drawing.Size(80,35)
    $btnMember.Location = New-Object System.Drawing.Point(200,60)

    $script:SelectedModule = $null

    $btnProvider.Add_Click({
        $script:SelectedModule = "Provider"
        $form.Close()
    })

    $btnClaims.Add_Click({
        $script:SelectedModule = "Claims"
        $form.Close()
    })

    $btnMember.Add_Click({
        $script:SelectedModule = "Member"
        $form.Close()
    })

    $form.Controls.Add($label)
    $form.Controls.Add($btnProvider)
    $form.Controls.Add($btnClaims)
    $form.Controls.Add($btnMember)

    [void]$form.ShowDialog()
    return $script:SelectedModule
}

if ($RunAll.ToUpper() -ne "Y" -and [string]::IsNullOrWhiteSpace($RunModule)) {
    $RunModule = Show-ModulePopup

    if ([string]::IsNullOrWhiteSpace($RunModule)) {
        [System.Windows.Forms.MessageBox]::Show("No option selected. Script will stop.")
        exit
    }
}

Write-Progress -Activity "Executin Task" -Status "Started" -PercentComplete 0
