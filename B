        "Provider" { Run-ProviderFlow }
        "Claims"   { Run-ClaimsFlow }
        "Member"   { Run-MemberFlow }
        "All"      { Run-AllFlow }
        default {
            [System.Windows.Forms.MessageBox]::Show(
                "No valid module selected.",
                "Facets Automation"
            )
        }
    }
}

# -----------------------------
# Main
# -----------------------------
Initialize-RunFolders

