package com.acfc.automation.util;

import com.acfc.automation.config.FrameworkConfig;

import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;

public final class FileResolver {

    private FileResolver() {
    }

    public static Path resolve(String inputPath) {
        if (inputPath == null || inputPath.isBlank()) {
            throw new RuntimeException("Input path is null or blank");
        }

        String trimmed = inputPath.trim();

        // 1. Absolute path
        Path direct = Paths.get(trimmed);
        if (direct.isAbsolute() && Files.exists(direct)) {
            return direct.toAbsolutePath().normalize();
        }

        // 2. Direct relative path from current working directory
        if (Files.exists(direct)) {
            return direct.toAbsolutePath().normalize();
        }

        // 3. Relative path under src/test/resources
        Path resourcePath = FrameworkConfig.testResourcesDir().resolve(trimmed);
        if (Files.exists(resourcePath)) {
            return resourcePath.toAbsolutePath().normalize();
        }

        throw new RuntimeException(
                "File not found. Checked absolute/direct/resources paths for: " + inputPath
        );
    }

    public static boolean exists(String inputPath) {
        try {
            resolve(inputPath);
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    public static String resolveAsString(String inputPath) {
        return resolve(inputPath).toString();
    }
}
