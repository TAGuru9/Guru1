test {
    useJUnitPlatform()

    include '**/ProjectRunnerTest.class'

    systemProperties(System.getProperties())

    testLogging {
        events 'passed', 'failed', 'skipped', 'standard_out', 'standard_error'
        showStandardStreams = true
        exceptionFormat 'full'
    }

    doFirst {
        println "DEBUG build.gradle tcFile   = ${System.getProperty('tcFile')}"
        println "DEBUG build.gradle tcfile   = ${System.getProperty('tcfile')}"
        println "DEBUG build.gradle ids      = ${System.getProperty('ids')}"
        println "DEBUG build.gradle names    = ${System.getProperty('names')}"
        println "DEBUG build.gradle dataFile = ${System.getProperty('dataFile')}"
        println "DEBUG build.gradle datafile = ${System.getProperty('datafile')}"
        println "DEBUG build.gradle test class include = ProjectRunnerTest"
    }
}
