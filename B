package com.acfc.automation.report.kpi;

import java.io.FileWriter;
import java.io.PrintWriter;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

public class KpiReporter {

    private static final Object LOCK = new Object();
    private static String runId;

    private KpiReporter() {
    }

    public static void initRun() {
        if (runId == null) {
            runId = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"));
        }
    }

    public static String getRunId() {
        initRun();
        return runId;
    }

    public static void writeTestcaseKpi(KpiEntry entry) {
        initRun();

        try {
            Path dir;
            if (entry.getReportPath() != null && !entry.getReportPath().isBlank()) {
                Path reportFile = Paths.get(entry.getReportPath());
                Path reportDir = reportFile.getParent();
                Path buildDir = reportDir;

                while (buildDir != null
                        && buildDir.getFileName() != null
                        && !buildDir.getFileName().toString().equalsIgnoreCase("build")) {
                    buildDir = buildDir.getParent();
                }

                if (buildDir != null) {
                    dir = buildDir.resolve("reports").resolve("kpi");
                } else {
                    dir = Paths.get("build", "reports", "kpi");
                }
            } else {
                dir = Paths.get("build", "reports", "kpi");
            }

            Files.createDirectories(dir);

            Path file = dir.resolve("KPI_" + runId + ".csv");
            boolean newFile = !Files.exists(file);

            synchronized (LOCK) {
                try (PrintWriter writer = new PrintWriter(new FileWriter(file.toFile(), true))) {
                    if (newFile) {
                        writer.println(
                                "runId,project,suite,type,env,tcId,tcName,executionMode,iteration,status,durationMs,"
                                        + "dataFile,payloadFile,reportPath,errorMessage,framework,site,changeId,product,"
                                        + "application,release,testSuiteType,repository,gitBranch,userId,buildUrl,"
                                        + "executor,executionSource,vm,testSuiteArgs"
                        );
                    }

                    writer.println(
                            csv(runId)
                                    + "," + csv(entry.getProject())
                                    + "," + csv(entry.getSuite())
                                    + "," + csv(entry.getType())
                                    + "," + csv(entry.getEnv())
                                    + "," + csv(entry.getTcId())
                                    + "," + csv(entry.getTcName())
                                    + "," + csv(entry.getExecutionMode())
                                    + "," + csv(entry.getIteration())
                                    + "," + csv(entry.getStatus())
                                    + "," + entry.getDurationMs()
                                    + "," + csv(entry.getDataFile())
                                    + "," + csv(entry.getPayloadFile())
                                    + "," + csv(entry.getReportPath())
                                    + "," + csv(entry.getErrorMessage())
                                    + "," + csv(KpiRuntimeParams.framework())
                                    + "," + csv(KpiRuntimeParams.site())
                                    + "," + csv(KpiRuntimeParams.changeId())
                                    + "," + csv(KpiRuntimeParams.product())
                                    + "," + csv(KpiRuntimeParams.application())
                                    + "," + csv(KpiRuntimeParams.release())
                                    + "," + csv(KpiRuntimeParams.testSuiteType())
                                    + "," + csv(KpiRuntimeParams.repository())
                                    + "," + csv(KpiRuntimeParams.gitBranch())
                                    + "," + csv(KpiRuntimeParams.userId())
                                    + "," + csv(KpiRuntimeParams.buildUrl())
                                    + "," + csv(KpiRuntimeParams.executor())
                                    + "," + csv(KpiRuntimeParams.executionSource())
                                    + "," + csv(KpiRuntimeParams.vm())
                                    + "," + csv(KpiRuntimeParams.testSuiteArgs(entry.getReportPath()))
                    );
                }
            }

            System.out.println("KPI written for testcase: " + safe(entry.getTcId()));
        } catch (Exception e) {
            System.out.println("Failed to write testcase KPI csv: " + e.getMessage());
            e.printStackTrace();
        }
    }

    public static void writeSuiteSummaryKpi(String project,
                                            String suite,
                                            String type,
                                            String env,
                                            int total,
                                            int passed,
                                            int failed,
                                            int skipped,
                                            long durationMs,
                                            String reportPath) {
        initRun();

        try {
            Path dir;
            if (reportPath != null && !reportPath.isBlank()) {
                Path reportFile = Paths.get(reportPath);
                Path reportDir = reportFile.getParent();
                Path buildDir = reportDir;

                while (buildDir != null
                        && buildDir.getFileName() != null
                        && !buildDir.getFileName().toString().equalsIgnoreCase("build")) {
                    buildDir = buildDir.getParent();
                }

                if (buildDir != null) {
                    dir = buildDir.resolve("reports").resolve("kpi");
                } else {
                    dir = Paths.get("build", "reports", "kpi");
                }
            } else {
                dir = Paths.get("build", "reports", "kpi");
            }

            Files.createDirectories(dir);

            Path file = dir.resolve("KPI_SUITE_" + runId + ".csv");
            boolean newFile = !Files.exists(file);

            synchronized (LOCK) {
                try (PrintWriter writer = new PrintWriter(new FileWriter(file.toFile(), true))) {
                    if (newFile) {
                        writer.println(
                                "runId,project,suite,type,env,total,passed,failed,skipped,durationMs,reportPath,"
                                        + "framework,site,changeId,product,application,release,testSuiteType,repository,"
                                        + "gitBranch,userId,buildUrl,executor,executionSource,vm,testSuiteArgs"
                        );
                    }

                    writer.println(
                            csv(runId)
                                    + "," + csv(project)
                                    + "," + csv(suite)
                                    + "," + csv(type)
                                    + "," + csv(env)
                                    + "," + total
                                    + "," + passed
                                    + "," + failed
                                    + "," + skipped
                                    + "," + durationMs
                                    + "," + csv(reportPath)
                                    + "," + csv(KpiRuntimeParams.framework())
                                    + "," + csv(KpiRuntimeParams.site())
                                    + "," + csv(KpiRuntimeParams.changeId())
                                    + "," + csv(KpiRuntimeParams.product())
                                    + "," + csv(KpiRuntimeParams.application())
                                    + "," + csv(KpiRuntimeParams.release())
                                    + "," + csv(KpiRuntimeParams.testSuiteType())
                                    + "," + csv(KpiRuntimeParams.repository())
                                    + "," + csv(KpiRuntimeParams.gitBranch())
                                    + "," + csv(KpiRuntimeParams.userId())
                                    + "," + csv(KpiRuntimeParams.buildUrl())
                                    + "," + csv(KpiRuntimeParams.executor())
                                    + "," + csv(KpiRuntimeParams.executionSource())
                                    + "," + csv(KpiRuntimeParams.vm())
                                    + "," + csv(KpiRuntimeParams.testSuiteArgs(reportPath))
                    );
                }
            }

            insertSuiteSummaryToDb(project, suite, type, env, total, passed, failed, skipped, durationMs, reportPath);

            System.out.println("KPI suite summary written and inserted successfully.");
        } catch (Exception e) {
            System.out.println("Failed to write suite summary KPI: " + e.getMessage());
            e.printStackTrace();
        }
    }

    private static void insertSuiteSummaryToDb(String project,
                                               String suite,
                                               String type,
                                               String env,
                                               int total,
                                               int passed,
                                               int failed,
                                               int skipped,
                                               long durationMs,
                                               String reportPath) {
        try {
            String dbUrl = firstNonBlank(
                    System.getProperty("kpi.db.url"),
                    System.getProperty("mysql.url"),
                    System.getProperty("db.url")
            );
            String dbUser = firstNonBlank(
                    System.getProperty("kpi.db.username"),
                    System.getProperty("mysql.username"),
                    System.getProperty("db.username")
            );
            String dbPassword = firstNonBlank(
                    System.getProperty("kpi.db.password"),
                    System.getProperty("mysql.password"),
                    System.getProperty("db.password")
            );

            if (isBlank(dbUrl) || isBlank(dbUser)) {
                System.out.println("KPI DB insert skipped: DB connection properties not configured.");
                return;
            }

            String status;
            if (failed > 0) {
                status = "FAIL";
            } else if (passed > 0 && failed == 0) {
                status = "PASS";
            } else {
                status = "WARN";
            }

            double percentage = total > 0 ? ((double) passed * 100.0) / total : 0.0;

            String sql = "INSERT INTO ta_reporting.ta_model ("
                    + "TA_FRAMEWORK, TA_SITE, TA_CHANGEID, TA_PRODUCT, TA_APPLICATION, TA_ENVTYPE, "
                    + "TA_RELEASE, TA_TESTSUITE_TYPE, TA_REPOSITORY, TA_BUILD_GIT_BRANCH, TA_TESTSUITE_ARGS, "
                    + "TA_USERID, TA_STATUS, TA_PASS, TA_FAIL, TA_SKIPWARN, TA_PERCENTAGE, "
                    + "TA_BUILD_URL, TA_EXECUTOR, TA_EXECUTION_SOURCE, TA_VM"
                    + ") VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";

            try (Connection connection = DriverManager.getConnection(dbUrl, dbUser, dbPassword);
                 PreparedStatement ps = connection.prepareStatement(sql)) {

                int i = 1;
                ps.setString(i++, KpiRuntimeParams.framework());
                ps.setString(i++, KpiRuntimeParams.site());
                ps.setString(i++, KpiRuntimeParams.changeId());
                ps.setString(i++, KpiRuntimeParams.product());
                ps.setString(i++, KpiRuntimeParams.application());
                ps.setString(i++, KpiRuntimeParams.envType());
                ps.setString(i++, KpiRuntimeParams.release());
                ps.setString(i++, KpiRuntimeParams.testSuiteType());
                ps.setString(i++, KpiRuntimeParams.repository());
                ps.setString(i++, KpiRuntimeParams.gitBranch());
                ps.setString(i++, KpiRuntimeParams.testSuiteArgs(reportPath));
                ps.setString(i++, KpiRuntimeParams.userId());
                ps.setString(i++, status);
                ps.setInt(i++, passed);
                ps.setInt(i++, failed);
                ps.setInt(i++, skipped);
                ps.setDouble(i++, percentage);
                ps.setString(i++, KpiRuntimeParams.buildUrl());
                ps.setString(i++, KpiRuntimeParams.executor());
                ps.setString(i++, KpiRuntimeParams.executionSource());
                ps.setString(i++, KpiRuntimeParams.vm());

                System.out.println("framework       = " + KpiRuntimeParams.framework());
                System.out.println("site            = " + KpiRuntimeParams.site());
                System.out.println("changeId        = " + KpiRuntimeParams.changeId());
                System.out.println("product         = " + KpiRuntimeParams.product());
                System.out.println("application     = " + KpiRuntimeParams.application());
                System.out.println("envType         = " + KpiRuntimeParams.envType());
                System.out.println("release         = " + KpiRuntimeParams.release());
                System.out.println("testSuiteType   = " + KpiRuntimeParams.testSuiteType());
                System.out.println("repository      = " + KpiRuntimeParams.repository());
                System.out.println("gitBranch       = " + KpiRuntimeParams.gitBranch());
                System.out.println("testSuiteArgs   = " + KpiRuntimeParams.testSuiteArgs(reportPath));
                System.out.println("userId          = " + KpiRuntimeParams.userId());
                System.out.println("buildUrl        = " + KpiRuntimeParams.buildUrl());
                System.out.println("executor        = " + KpiRuntimeParams.executor());
                System.out.println("executionSource = " + KpiRuntimeParams.executionSource());
                System.out.println("vm              = " + KpiRuntimeParams.vm());

                ps.executeUpdate();
            }

            System.out.println("KPI inserted into ta_reporting.ta_model successfully.");
        } catch (Exception e) {
            System.out.println("Failed to insert KPI summary into MySQL: " + e.getMessage());
            e.printStackTrace();
        }
    }

    private static String firstNonBlank(String... values) {
        if (values == null) {
            return "";
        }

        for (String value : values) {
            if (value != null && !value.isBlank()) {
                return value.trim();
            }
        }

        return "";
    }

    private static boolean isBlank(String value) {
        return value == null || value.isBlank();
    }

    private static String csv(String value) {
        String v = safe(value).replace("\"", "\"\"");
        return "\"" + v + "\"";
    }

    private static String safe(String value) {
        return value == null || value.isBlank() ? "NA" : value.trim();
    }
}
