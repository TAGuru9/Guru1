package com.acfc.automation.report.kpi;

import java.io.FileWriter;
import java.io.PrintWriter;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

public class KpiReporter {

    private static final Object LOCK = new Object();
    private static String runId;

    private KpiReporter() {
    }

    public static void initRun() {
        if (runId == null) {
            runId = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"));
        }
    }

    public static String getRunId() {
        initRun();
        return runId;
    }

    public static void writeTestcaseKpi(KpiEntry entry) {
        initRun();

        try {
            Path dir = Paths.get(
                    safe(entry.getProject()),
                    "build",
                    "reports",
                    "kpi"
            );
            Files.createDirectories(dir);

            Path file = dir.resolve("kpi_" + runId + ".csv");
            boolean newFile = !Files.exists(file);

            synchronized (LOCK) {
                try (PrintWriter writer = new PrintWriter(new FileWriter(file.toFile(), true))) {
                    if (newFile) {
                        writer.println("runId,project,suite,type,env,tcId,tcName,executionMode,iteration,status,durationMs,dataFile,reportPath,errorMessage");
                    }

                    writer.println(csv(runId) + ","
                            + csv(entry.getProject()) + ","
                            + csv(entry.getSuite()) + ","
                            + csv(entry.getType()) + ","
                            + csv(entry.getEnv()) + ","
                            + csv(entry.getTcId()) + ","
                            + csv(entry.getTcName()) + ","
                            + csv(entry.getExecutionMode()) + ","
                            + csv(entry.getIteration()) + ","
                            + csv(entry.getStatus()) + ","
                            + entry.getDurationMs() + ","
                            + csv(entry.getDataFile()) + ","
                            + csv(entry.getReportPath()) + ","
                            + csv(entry.getErrorMessage()));
                }
            }

            System.out.println("KPI written for testcase: " + safe(entry.getTcId()));
        } catch (Exception e) {
            System.out.println("Failed to write testcase KPI: " + e.getMessage());
        }
    }

    public static void writeSuiteSummaryKpi(String project,
                                            String suite,
                                            String type,
                                            String env,
                                            int total,
                                            int passed,
                                            int failed,
                                            int skipped,
                                            long durationMs,
                                            String reportPath) {
        initRun();

        try {
            Path dir = Paths.get(
                    safe(project),
                    "build",
                    "reports",
                    "kpi"
            );
            Files.createDirectories(dir);

            Path file = dir.resolve("kpi_summary_" + runId + ".csv");
            boolean newFile = !Files.exists(file);

            synchronized (LOCK) {
                try (PrintWriter writer = new PrintWriter(new FileWriter(file.toFile(), true))) {
                    if (newFile) {
                        writer.println("runId,project,suite,type,env,total,passed,failed,skipped,durationMs,reportPath");
                    }

                    writer.println(csv(runId) + ","
                            + csv(project) + ","
                            + csv(suite) + ","
                            + csv(type) + ","
                            + csv(env) + ","
                            + total + ","
                            + passed + ","
                            + failed + ","
                            + skipped + ","
                            + durationMs + ","
                            + csv(reportPath));
                }
            }

            System.out.println("KPI suite summary written.");
        } catch (Exception e) {
            System.out.println("Failed to write suite KPI summary: " + e.getMessage());
        }
    }

    private static String csv(String value) {
        String v = safe(value).replace("\"", "\"\"");
        return "\"" + v + "\"";
    }

    private static String safe(String value) {
        return value == null || value.isBlank() ? "NA" : value.trim();
    }
}
