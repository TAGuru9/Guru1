# -----------------------------
# Facets reusable app functions
# -----------------------------
function Start-FacetsApp {
    param(
        [string]$ExePath = "C:\Program Files (x86)\TriZetto\Facets\System\Bin\carexe.exe"
    )

    if (-not (Test-Path $ExePath)) {
        throw "Facets application not found: $ExePath"
    }

    Start-Process -FilePath $ExePath
    TA-Sleep -Seconds 5
}

function Stop-FacetsApp {
    $proc = Get-Process -Name "carexe" -ErrorAction SilentlyContinue
    if ($proc) {
        $proc | Stop-Process -Force
        TA-Sleep -Seconds 2
    }
}

function Wait-ForFacets {
    param(
        [int]$TimeoutSeconds = 30
    )

    $elapsed = 0
    while ($elapsed -lt $TimeoutSeconds) {
        $proc = Get-Process -Name "carexe" -ErrorAction SilentlyContinue
        if ($proc) {
            return $true
        }
        Start-Sleep -Seconds 1
        $elapsed++
    }

    throw "Facets process did not start within $TimeoutSeconds seconds."
}

function Handle-FacetsError {
    $wshell = New-Object -ComObject WScript.Shell
    if ($wshell.AppActivate("Facets - Error")) {
        New-Screenshot -StepName "Facets_Error" | Out-Null
        TA-Sleep -Seconds 1
        $wshell.SendKeys("{ENTER}")
        throw "Facets error popup detected."
    }
}

