package com.acfc.automation.data;

import com.acfc.automation.config.FrameworkConfig;

import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Pattern;

public final class TestDataReader {

    private TestDataReader() {
    }

    public static List<Map<String, String>> readData(String dataFile, String delimiter) {
        try {
            Path path = resolveDataPath(dataFile);

            System.out.println("DEBUG dataFile path   : " + path);
            System.out.println("DEBUG dataFile exists : " + Files.exists(path));

            List<String> lines = Files.readAllLines(path, StandardCharsets.UTF_8);
            List<String> nonEmpty = new ArrayList<>();

            for (String line : lines) {
                if (line != null && !line.trim().isEmpty()) {
                    nonEmpty.add(line);
                }
            }

            if (nonEmpty.isEmpty()) {
                return new ArrayList<>();
            }

            String actualDelimiter = (delimiter == null || delimiter.isBlank()) ? "," : delimiter;
            String[] headers = nonEmpty.get(0).split(Pattern.quote(actualDelimiter), -1);

            List<Map<String, String>> rows = new ArrayList<>();

            for (int i = 1; i < nonEmpty.size(); i++) {
                String[] values = nonEmpty.get(i).split(Pattern.quote(actualDelimiter), -1);
                Map<String, String> row = new LinkedHashMap<>();

                for (int j = 0; j < headers.length; j++) {
                    String key = clean(headers[j]);
                    String value = j < values.length ? clean(values[j]) : "";
                    row.put(key, value);
                }

                rows.add(row);
            }

            return rows;
        } catch (Exception e) {
            throw new RuntimeException("Failed to read data file: " + dataFile, e);
        }
    }

    private static Path resolveDataPath(String dataFile) {
        Path direct = Path.of(dataFile).toAbsolutePath().normalize();
        if (Files.exists(direct)) {
            return direct;
        }

        Path underResources = FrameworkConfig.testResourcesDir()
                .resolve("testdata")
                .resolve(Path.of(dataFile).getFileName().toString())
                .toAbsolutePath()
                .normalize();

        if (Files.exists(underResources)) {
            return underResources;
        }

        Path relativeResource = FrameworkConfig.testResourcesDir()
                .resolve(dataFile)
                .toAbsolutePath()
                .normalize();

        if (Files.exists(relativeResource)) {
            return relativeResource;
        }

        throw new RuntimeException("Data file not found: " + dataFile);
    }

    private static String clean(String value) {
        if (value == null) {
            return "";
        }
        String trimmed = value.trim();
        if (trimmed.startsWith("\"") && trimmed.endsWith("\"") && trimmed.length() >= 2) {
            return trimmed.substring(1, trimmed.length() - 1).trim();
        }
        return trimmed;
    }
}
