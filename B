package com.acfc.automation.context;

import java.util.Collections;
import java.util.LinkedHashMap;
import java.util.Map;

public final class ExecutionContext {

    private static final Map<String, Object> CONTEXT = new LinkedHashMap<>();

    private ExecutionContext() {
    }

    public static synchronized void clear() {
        CONTEXT.clear();
    }

    public static synchronized void put(String key, Object value) {
        CONTEXT.put(key, value);
    }

    public static synchronized Object get(String key) {
        return CONTEXT.get(key);
    }

    public static synchronized Map<String, Object> getAll() {
        return Collections.unmodifiableMap(new LinkedHashMap<>(CONTEXT));
    }

    public static synchronized String getAsString(String key) {
        Object value = CONTEXT.get(key);
        return value == null ? "" : String.valueOf(value);
    }
}
