Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

function Show-ModulePopup {

    $script:SelectedModule = $null

    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Facets Automation"
    $form.Size = New-Object System.Drawing.Size(420,260)
    $form.StartPosition = "CenterScreen"
    $form.FormBorderStyle = "FixedDialog"
    $form.MaximizeBox = $false
    $form.MinimizeBox = $false
    $form.BackColor = [System.Drawing.Color]::WhiteSmoke
    $form.TopMost = $true

    $titleLabel = New-Object System.Windows.Forms.Label
    $titleLabel.Text = "Select Module"
    $titleLabel.Font = New-Object System.Drawing.Font("Segoe UI",14,[System.Drawing.FontStyle]::Bold)
    $titleLabel.AutoSize = $true
    $titleLabel.Location = New-Object System.Drawing.Point(135,20)
    $titleLabel.ForeColor = [System.Drawing.Color]::FromArgb(30,30,30)

    $descLabel = New-Object System.Windows.Forms.Label
    $descLabel.Text = "Choose which Facets flow you want to run"
    $descLabel.Font = New-Object System.Drawing.Font("Segoe UI",9)
    $descLabel.AutoSize = $true
    $descLabel.Location = New-Object System.Drawing.Point(95,55)
    $descLabel.ForeColor = [System.Drawing.Color]::DimGray

    $groupBox = New-Object System.Windows.Forms.GroupBox
    $groupBox.Text = "Available Options"
    $groupBox.Size = New-Object System.Drawing.Size(360,110)
    $groupBox.Location = New-Object System.Drawing.Point(20,85)
    $groupBox.Font = New-Object System.Drawing.Font("Segoe UI",9,[System.Drawing.FontStyle]::Regular)

    function New-MenuButton {
        param(
            [string]$Text,
            [int]$X,
            [int]$Y,
            [int]$W = 95,
            [int]$H = 35
        )

        $btn = New-Object System.Windows.Forms.Button
        $btn.Text = $Text
        $btn.Size = New-Object System.Drawing.Size($W,$H)
        $btn.Location = New-Object System.Drawing.Point($X,$Y)
        $btn.Font = New-Object System.Drawing.Font("Segoe UI",9,[System.Drawing.FontStyle]::Regular)
        $btn.FlatStyle = "Standard"
        $btn.UseVisualStyleBackColor = $true
        return $btn
    }

    $btnProvider = New-MenuButton -Text "Provider" -X 20  -Y 30
    $btnClaims   = New-MenuButton -Text "Claims"   -X 130 -Y 30
    $btnMember   = New-MenuButton -Text "Member"   -X 240 -Y 30
    $btnAll      = New-MenuButton -Text "Run All"  -X 130 -Y 70

    $btnCancel = New-Object System.Windows.Forms.Button
    $btnCancel.Text = "Cancel"
    $btnCancel.Size = New-Object System.Drawing.Size(90,32)
    $btnCancel.Location = New-Object System.Drawing.Point(155,205)
    $btnCancel.Font = New-Object System.Drawing.Font("Segoe UI",9)

    $btnProvider.Add_Click({
        $script:SelectedModule = "Provider"
        $form.Close()
    })

    $btnClaims.Add_Click({
        $script:SelectedModule = "Claims"
        $form.Close()
    })

    $btnMember.Add_Click({
        $script:SelectedModule = "Member"
        $form.Close()
    })

    $btnAll.Add_Click({
        $script:SelectedModule = "All"
        $form.Close()
    })

    $btnCancel.Add_Click({
        $script:SelectedModule = $null
        $form.Close()
    })

    $groupBox.Controls.Add($btnProvider)
    $groupBox.Controls.Add($btnClaims)
    $groupBox.Controls.Add($btnMember)
    $groupBox.Controls.Add($btnAll)

    $form.Controls.Add($titleLabel)
    $form.Controls.Add($descLabel)
    $form.Controls.Add($groupBox)
    $form.Controls.Add($btnCancel)

    $form.AcceptButton = $btnProvider
    $form.CancelButton = $btnCancel

    [void]$form.ShowDialog()
    return $script:SelectedModule
}
