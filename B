private int executeSingleRow(TestCase testCase, Map<String, String> currentRow, int iteration) throws Exception {
    Map<String, String> workingRow = new LinkedHashMap<>(currentRow);

    if (testCase.getQuery() != null && !isBlank(testCase.getQuery().getSql())) {
        Map<String, String> dbValues = executeDbAndStoreValues(testCase.getQuery(), workingRow);
        if (!dbValues.isEmpty()) {
            workingRow.putAll(dbValues);
            System.out.println("DB Values Loaded : " + dbValues);
        }
    }

    String baseUrl = getBaseUrl(testCase);
    String endpoint = resolveText(defaultString(testCase.getEndpoint()), workingRow, testCase.getPayloadData());
    String url = baseUrl + endpoint;

    String requestBody = buildRequestBody(testCase, workingRow);
    Map<String, String> resolvedHeaders = buildHeaders(testCase, workingRow);

    int expectedStatus = getExpectedStatus(testCase, workingRow);
    String expectedMessage = getExpectedMessage(testCase, workingRow);
    String scenarioType = getScenarioType(testCase, workingRow);

    System.out.println("--------------------------------------------------");
    System.out.println("Iteration      : " + iteration);
    System.out.println("Scenario Type  : " + scenarioType);
    System.out.println("URL            : " + url);
    System.out.println("ExpectedStatus : " + expectedStatus);
    System.out.println("ExpectedMsg    : " + expectedMessage);
    System.out.println("Headers        : " + resolvedHeaders);
    System.out.println("Working Row    : " + workingRow);
    System.out.println("Request Body   : ");
    System.out.println(requestBody);

    Response response = sendRequest(testCase.getMethod(), url, resolvedHeaders, requestBody);

    int actualStatus = response.getStatusCode();
    String responseBody = response.getBody() == null ? "" : response.getBody().asString();

    System.out.println("Actual Status  : " + actualStatus);
    System.out.println("Response Body  : ");
    System.out.println(responseBody);

    validateStatus(expectedStatus, actualStatus, workingRow);
    validateExpectedMessage(expectedMessage, responseBody, workingRow);
    validateExpectedBodyContains(testCase, responseBody);
    validateExpectedBodyXpaths(testCase, responseBody, workingRow);

    Map<String, String> extractedValues = extractResponseValues(testCase, responseBody);
    if (!extractedValues.isEmpty()) {
        System.out.println("Extracted Values: " + extractedValues);
    }

    validateFileVsResponse(testCase, workingRow, extractedValues);
    validateDbValuesAgainstResponse(testCase.getQuery(), workingRow, extractedValues, responseBody);

    System.out.println("Iteration " + iteration + " PASSED");
    System.out.println("Manual QA Note: " + buildManualQaMessage(expectedStatus, actualStatus));
    System.out.println("--------------------------------------------------");

    return actualStatus;
}
