package com.acfc.automation.runner;

import com.acfc.automation.config.FrameworkConfig;
import com.acfc.automation.context.ExecutionContext;
import com.acfc.automation.engine.ApiExecutionEngine;
import com.acfc.automation.model.ExecutionResult;
import com.acfc.automation.model.TestCase;
import com.acfc.automation.report.ExtentReportManager;
import com.acfc.automation.report.ExecutionResultStore;
import com.acfc.automation.report.SummaryTracker;
import com.acfc.automation.util.TestDataReader;
import org.junit.jupiter.api.AfterAll;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api.DynamicTest;
import org.junit.jupiter.api.TestFactory;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;
import java.util.stream.IntStream;

public abstract class ConfigDrivenApiRunner {

    private static final ApiExecutionEngine engine = new ApiExecutionEngine();

    protected abstract String project();

    protected String suite() {
        return null;
    }

    @TestFactory
    public List<DynamicTest> execution() throws Exception {
        SummaryTracker.startSuite();
        ExecutionResultStore.clear();

        String testCaseFile = System.getProperty("tcFile");
        String dataFile = System.getProperty("dataFile");

        if (testCaseFile == null || testCaseFile.isBlank()) {
            throw new IllegalArgumentException("Missing system property: tcFile");
        }

        // Case 1: CSV / TXT execution
        if (dataFile != null && !dataFile.isBlank()) {

            List<Map<String, String>> records = TestDataReader.readData(dataFile, ",");
            List<TestCase> parsedCases = TestCaseFileLoader.parse(testCaseFile);

            if (parsedCases == null || parsedCases.isEmpty()) {
                throw new IllegalArgumentException("No test case found in file: " + testCaseFile);
            }

            TestCase testCase = parsedCases.get(0);

            return IntStream.range(0, records.size())
                    .mapToObj(i -> DynamicTest.dynamicTest(
                            "Iteration " + (i + 1),
                            () -> {
                                Map<String, String> record = records.get(i);

                                ExecutionContext.clear();
                                ExecutionContext.put("iteration", String.valueOf(i + 1));
                                record.forEach(ExecutionContext::put);

                                ExecutionResult result = engine.execute(testCase);
                                ExecutionResultStore.add(result);
                                SummaryTracker.record(result);

                                System.out.printf(
                                        "%s | %s | %s | Exp=%s | Act=%s | %s%n",
                                        safe(result.getProject()),
                                        safe(result.getId()),
                                        safe(result.getName()),
                                        result.getExpectedStatus(),
                                        result.getActualStatus(),
                                        safe(result.getStatus())
                                );

                                Assertions.assertEquals(
                                        "PASS",
                                        safe(result.getStatus()).toUpperCase(),
                                        "Test failed for iteration: " + (i + 1)
                                );
                            }
                    ))
                    .collect(Collectors.toList());
        }

        // Case 2: Normal execution - no CSV/TXT
        List<TestCase> cases = TestCaseFilter.filter(TestCaseLoader.loadAll());

        return cases.stream()
                .map(tc -> DynamicTest.dynamicTest(
                        safe(tc.getId()) + " - " + safe(tc.getName()),
                        () -> {
                            ExecutionContext.clear();

                            ExecutionResult result = engine.execute(tc);
                            ExecutionResultStore.add(result);
                            SummaryTracker.record(result);

                            System.out.printf(
                                    "%s | %s | %s | Exp=%s | Act=%s | %s%n",
                                    safe(result.getProject()),
                                    safe(result.getId()),
                                    safe(result.getName()),
                                    result.getExpectedStatus(),
                                    result.getActualStatus(),
                                    safe(result.getStatus())
                            );

                            Assertions.assertEquals(
                                    "PASS",
                                    safe(result.getStatus()).toUpperCase(),
                                    "Single test failed: " + safe(tc.getId())
                            );
                        }
                ))
                .collect(Collectors.toList());
    }

    @AfterAll
    public static void afterAll() {
        SummaryTracker.endSuite();
        SummaryTracker.printSummary(
                System.getProperty("project", FrameworkConfig.projectName()),
                System.getProperty("env", FrameworkConfig.env())
        );
        ExtentReportManager.flush();
    }

    private static String safe(String value) {
        return value == null ? "" : value.trim();
    }
}
